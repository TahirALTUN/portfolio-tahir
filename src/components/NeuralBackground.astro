---
---

<canvas id="neural-canvas" class="neural-canvas" aria-hidden="true"></canvas>

<style>
  .neural-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  function initNeuralNetwork() {
    const canvas = document.getElementById('neural-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animationId: number;
    let particles: Particle[] = [];
    let mouse = { x: -9999, y: -9999 };
    let width = 0;
    let height = 0;

    const CONFIG = {
      particleCount: 80,
      maxDistance: 160,
      mouseRadius: 200,
      particleMinSize: 1.2,
      particleMaxSize: 2.8,
      speedFactor: 0.35,
      lineColor: { r: 160, g: 130, b: 100 },   // warm earth tone
      dotColor: { r: 176, g: 126, b: 98 },      // accent-warm
      mouseLineColor: { r: 94, g: 135, b: 168 }, // accent-cool
      lineOpacity: 0.12,
      dotOpacity: 0.35,
    };

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      opacity: number;
      pulseSpeed: number;
      pulsePhase: number;
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      canvas.style.width = width + 'px';
      canvas.style.height = height + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

      // Adjust particle count for smaller screens
      const targetCount = width < 768 ? 40 : CONFIG.particleCount;
      while (particles.length < targetCount) {
        particles.push(createParticle());
      }
      while (particles.length > targetCount) {
        particles.pop();
      }
    }

    function createParticle(): Particle {
      return {
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * CONFIG.speedFactor,
        vy: (Math.random() - 0.5) * CONFIG.speedFactor,
        size: CONFIG.particleMinSize + Math.random() * (CONFIG.particleMaxSize - CONFIG.particleMinSize),
        opacity: 0.2 + Math.random() * 0.5,
        pulseSpeed: 0.005 + Math.random() * 0.015,
        pulsePhase: Math.random() * Math.PI * 2,
      };
    }

    function drawLine(x1: number, y1: number, x2: number, y2: number, opacity: number, color: { r: number; g: number; b: number }) {
      ctx!.beginPath();
      ctx!.moveTo(x1, y1);
      ctx!.lineTo(x2, y2);
      ctx!.strokeStyle = `rgba(${color.r}, ${color.g}, ${color.b}, ${opacity})`;
      ctx!.lineWidth = 0.6;
      ctx!.stroke();
    }

    function animate(time: number) {
      ctx!.clearRect(0, 0, width, height);

      // Update particles
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;

        // Bounce off edges with soft wrapping
        if (p.x < -20) p.x = width + 20;
        if (p.x > width + 20) p.x = -20;
        if (p.y < -20) p.y = height + 20;
        if (p.y > height + 20) p.y = -20;

        // Pulse
        p.pulsePhase += p.pulseSpeed;
      }

      // Draw connections between particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONFIG.maxDistance) {
            const opacity = CONFIG.lineOpacity * (1 - dist / CONFIG.maxDistance);
            drawLine(particles[i].x, particles[i].y, particles[j].x, particles[j].y, opacity, CONFIG.lineColor);
          }
        }
      }

      // Draw mouse connections
      const mx = mouse.x;
      const my = mouse.y;
      if (mx > -1000) {
        for (const p of particles) {
          const dx = p.x - mx;
          const dy = p.y - my;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONFIG.mouseRadius) {
            const opacity = 0.18 * (1 - dist / CONFIG.mouseRadius);
            drawLine(p.x, p.y, mx, my, opacity, CONFIG.mouseLineColor);

            // Gentle repulsion from mouse
            const force = (1 - dist / CONFIG.mouseRadius) * 0.15;
            p.vx += (dx / dist) * force;
            p.vy += (dy / dist) * force;

            // Dampen velocity
            p.vx *= 0.99;
            p.vy *= 0.99;
          }
        }
      }

      // Draw particles
      for (const p of particles) {
        const pulse = 0.6 + 0.4 * Math.sin(p.pulsePhase);
        const alpha = p.opacity * pulse * CONFIG.dotOpacity;
        const { r, g, b } = CONFIG.dotColor;

        // Glow
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha * 0.15})`;
        ctx!.fill();

        // Core dot
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        ctx!.fill();
      }

      animationId = requestAnimationFrame(animate);
    }

    // Event listeners
    function onMouseMove(e: MouseEvent) {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    }

    function onMouseLeave() {
      mouse.x = -9999;
      mouse.y = -9999;
    }

    function onTouchMove(e: TouchEvent) {
      if (e.touches.length > 0) {
        mouse.x = e.touches[0].clientX;
        mouse.y = e.touches[0].clientY;
      }
    }

    function onTouchEnd() {
      mouse.x = -9999;
      mouse.y = -9999;
    }

    // Init
    resize();
    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', onMouseMove);
    window.addEventListener('mouseleave', onMouseLeave);
    window.addEventListener('touchmove', onTouchMove, { passive: true });
    window.addEventListener('touchend', onTouchEnd);

    animationId = requestAnimationFrame(animate);

    // Cleanup on navigation (Astro view transitions)
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
      window.removeEventListener('mousemove', onMouseMove);
      window.removeEventListener('mouseleave', onMouseLeave);
      window.removeEventListener('touchmove', onTouchMove);
      window.removeEventListener('touchend', onTouchEnd);
    }, { once: true });
  }

  // Run on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNeuralNetwork);
  } else {
    initNeuralNetwork();
  }
  document.addEventListener('astro:page-load', initNeuralNetwork);
</script>
