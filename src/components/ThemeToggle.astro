---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="theme-switcher-wrap">
  <button
    type="button"
    class="theme-switch"
    id="theme-switch"
    role="switch"
    aria-checked="false"
    aria-label={t('theme.toggle')}
    title={t('theme.toggle')}
    data-theme-switch
  >
    <span class="theme-switch-track" id="theme-switch-track">
      <span class="theme-switch-icon theme-switch-sun" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2"/>
        </svg>
      </span>
      <span class="theme-switch-icon theme-switch-moon" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </span>
      <span class="theme-switch-thumb" id="theme-switch-thumb"></span>
    </span>
  </button>
</div>

<style>
  .theme-switcher-wrap {
    margin-top: 0;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .theme-switch {
    all: unset;
    box-sizing: border-box;
    cursor: grab;
    display: block;
    padding: 3px;
    border: 1.5px solid var(--ink-high);
    background: var(--surface-2);
    border-radius: 999px;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .theme-switch:active {
    cursor: grabbing;
  }

  .theme-switch:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 3px;
  }

  .theme-switch-track {
    position: relative;
    display: block;
    width: 40px;
    height: 20px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface-3) 85%, var(--ink-high) 15%);
    touch-action: none;
  }

  .theme-switch-icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-mid);
    pointer-events: none;
    z-index: 1;
    opacity: 0.85;
  }

  .theme-switch-sun {
    left: 4px;
  }

  .theme-switch-moon {
    right: 4px;
  }

  .theme-switch-thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--ink-high);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    z-index: 2;
    transition: transform 0.28s cubic-bezier(0.25, 1, 0.3, 1);
    touch-action: none;
  }

  :global(html[data-theme="dark"]) .theme-switch-thumb {
    transform: translateX(20px);
  }

  :global(html[data-theme="dark"]) .theme-switch-sun {
    opacity: 0.35;
  }

  :global(html[data-theme="dark"]) .theme-switch-moon {
    opacity: 1;
    color: var(--ink-high);
  }

  :global(html:not([data-theme="dark"])) .theme-switch-moon {
    opacity: 0.35;
  }

  :global(html:not([data-theme="dark"])) .theme-switch-sun {
    opacity: 1;
    color: var(--ink-high);
  }

  @media (max-width: 768px) {
    .theme-switcher-wrap {
      margin-top: 0;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'portfolio-theme';

  function getStoredTheme(): 'light' | 'dark' {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      if (v === 'dark' || v === 'light') return v;
    } catch {
      /* ignore */
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(theme: 'light' | 'dark') {
    const root = document.documentElement;
    if (theme === 'dark') root.setAttribute('data-theme', 'dark');
    else root.removeAttribute('data-theme');
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {
      /* ignore */
    }
    const btn = document.querySelector<HTMLButtonElement>('[data-theme-switch]');
    if (btn) btn.setAttribute('aria-checked', theme === 'dark' ? 'true' : 'false');
    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme } }));
  }

  function initThemeSwitch() {
    const btn = document.querySelector<HTMLButtonElement>('[data-theme-switch]');
    const track = document.getElementById('theme-switch-track');
    const thumb = document.getElementById('theme-switch-thumb');
    if (!btn || !track || !thumb) return;

    applyTheme(getStoredTheme());

    const trackWidth = () => track.getBoundingClientRect().width;
    const thumbWidth = () => thumb.getBoundingClientRect().width;
    const maxSlide = () => Math.max(0, trackWidth() - thumbWidth() - 4);

    let dragging = false;
    let startX = 0;
    let startSlide = 0;

    function themeFromSlide(x: number): 'light' | 'dark' {
      return x > maxSlide() * 0.5 ? 'dark' : 'light';
    }

    function setThumbWhileDrag(slidePx: number) {
      const m = maxSlide();
      const clamped = Math.max(0, Math.min(m, slidePx));
      thumb.style.transition = 'none';
      thumb.style.transform = `translateX(${clamped}px)`;
    }

    function endDrag(finalSlide: number) {
      thumb.style.transition = '';
      thumb.style.transform = '';
      applyTheme(themeFromSlide(finalSlide));
    }

    function toggleTheme() {
      const cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      applyTheme(cur === 'dark' ? 'light' : 'dark');
    }

    let didDrag = false;
    let suppressNextClick = false;

    btn.addEventListener('click', () => {
      if (suppressNextClick) {
        suppressNextClick = false;
        return;
      }
      if (didDrag) {
        didDrag = false;
        return;
      }
      toggleTheme();
    });

    thumb.addEventListener('pointerdown', (e) => {
      e.stopPropagation();
      e.preventDefault();
      dragging = true;
      didDrag = false;
      startX = e.clientX;
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      startSlide = isDark ? maxSlide() : 0;
      thumb.setPointerCapture(e.pointerId);
    });

    thumb.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 4) didDrag = true;
      setThumbWhileDrag(startSlide + dx);
    });

    thumb.addEventListener('pointerup', (e) => {
      if (!dragging) return;
      dragging = false;
      try {
        thumb.releasePointerCapture(e.pointerId);
      } catch {
        /* ignore */
      }
      const rect = track.getBoundingClientRect();
      const thumbRect = thumb.getBoundingClientRect();
      const slide = thumbRect.left - rect.left - 2;

      if (!didDrag) {
        thumb.style.transition = '';
        thumb.style.transform = '';
        toggleTheme();
        suppressNextClick = true;
        return;
      }

      endDrag(slide);
    });

    thumb.addEventListener('pointercancel', () => {
      dragging = false;
      thumb.style.transition = '';
      thumb.style.transform = '';
      applyTheme(getStoredTheme());
    });
  }

  document.addEventListener('DOMContentLoaded', initThemeSwitch);
  document.addEventListener('astro:page-load', initThemeSwitch);
</script>
