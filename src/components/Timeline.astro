---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'tr';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const experiences = [
  {
    title: t('exp.1.title'),
    company: t('exp.1.company'),
    date: t('exp.1.date'),
    desc: t('exp.1.desc'),
    long: t('exp.1.long'),
    current: false,
  },
  {
    title: t('exp.2.title'),
    company: t('exp.2.company'),
    date: t('exp.2.date'),
    desc: t('exp.2.desc'),
    long: t('exp.2.long'),
    current: false,
  },
  {
    title: t('exp.3.title'),
    company: t('exp.3.company'),
    date: t('exp.3.date'),
    desc: t('exp.3.desc'),
    long: t('exp.3.long'),
    current: false,
  },
  {
    title: t('exp.4.title'),
    company: t('exp.4.company'),
    date: t('exp.4.date'),
    desc: t('exp.4.desc'),
    long: t('exp.4.long'),
    current: false,
  },
  {
    title: t('exp.5.title'),
    company: t('exp.5.company'),
    date: t('exp.5.date'),
    desc: t('exp.5.desc'),
    long: t('exp.5.long'),
    current: false,
  },
  {
    title: t('exp.6.title'),
    company: t('exp.6.company'),
    date: t('exp.6.date'),
    desc: t('exp.6.desc'),
    long: t('exp.6.long'),
    current: false,
  },
];

const education = [
  {
    title: t('edu.1.title'),
    university: t('edu.1.university'),
    date: t('edu.1.date'),
    long: t('edu.1.long'),
    current: true,
  },
  {
    title: t('edu.2.title'),
    university: t('edu.2.university'),
    date: t('edu.2.date'),
    long: t('edu.2.long'),
    current: false,
  },
];

const certifications = [ t('cert.1'), t('cert.2'), t('cert.3'), t('cert.4') ];
const volunteering = [ t('vol.1'), t('vol.2'), t('vol.3') ];
---

<div class="timeline-root">
  <div class="timeline-wrapper">

    <!-- Experience timeline -->
    <div class="timeline">
      <div class="timeline-spine" aria-hidden="true"></div>

      {experiences.map((exp, index) => (
        <div
          class={`timeline-item ${index % 2 === 0 ? 'tl-left' : 'tl-right'} reveal-on-scroll reveal-stagger timeline-item--openable`}
          style={`--stagger: ${index}`}
          data-timeline-kind="exp"
          data-timeline-index={String(index)}
          role="button"
          tabindex="0"
          aria-label={`${exp.title} — ${t('card.open')}`}
        >
          <div class="timeline-dot" class:list={[exp.current ? 'dot-active' : '']}></div>
          <div class="timeline-card">
            <div class="tl-card-header">
              <span class="tl-date">{exp.date}</span>
              {exp.current && <span class="tl-badge">{t('resume.experience.current')}</span>}
            </div>
            <h4 class="tl-title">{exp.title}</h4>
            <span class="tl-company">{exp.company}</span>
            {exp.desc && <p class="tl-desc">{exp.desc}</p>}
          </div>
        </div>
      ))}
    </div>

    <!-- Education + Certs/Volunteering -->
    <div class="lower-sections">
      
      <!-- Education -->
      <div class="lower-col reveal-on-scroll">
        <h3 class="lower-heading">{t('resume.education.title')}</h3>
        <div class="edu-list">
          {education.map((edu, i) => (
            <div
              class="edu-item edu-item--openable"
              data-timeline-kind="edu"
              data-timeline-index={String(i)}
              role="button"
              tabindex="0"
              aria-label={`${edu.title} — ${t('card.open')}`}
            >
              <div class="edu-meta">
                <span class="edu-date">{edu.date}</span>
                {edu.current && <span class="edu-current">{t('resume.experience.current')}</span>}
              </div>
              <h5 class="edu-title">{edu.title}</h5>
              <span class="edu-uni">{edu.university}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Certs + Volunteering -->
      <div class="lower-col">
        <div class="reveal-on-scroll">
          <h3 class="lower-heading">{t('resume.certifications.title')}</h3>
          <ul class="clean-list">
            {certifications.map(c => <li>{c}</li>)}
          </ul>
        </div>

        <div class="reveal-on-scroll" style="margin-top: 3rem;">
          <h3 class="lower-heading">{t('resume.volunteering.title')}</h3>
          <ul class="clean-list">
            {volunteering.map(v => <li>{v}</li>)}
          </ul>
        </div>
      </div>

    </div>
  </div>

  <div class="tl-detail-overlay" id="tl-detail-overlay" hidden>
    <button type="button" class="tl-detail-close" id="tl-detail-close" aria-label={t('timeline.detail.close')}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="tl-detail-inner">
      <p class="tl-detail-meta" id="tl-detail-meta"></p>
      <h3 class="tl-detail-title" id="tl-detail-title"></h3>
      <p class="tl-detail-sub" id="tl-detail-sub"></p>
      <div class="tl-detail-body" id="tl-detail-body"></div>
    </div>
  </div>
</div>

<script define:vars={{ experiences, education }}>
  function initTimelineDetail() {
    const overlay = document.getElementById('tl-detail-overlay');
    const closeBtn = document.getElementById('tl-detail-close');
    const metaEl = document.getElementById('tl-detail-meta');
    const titleEl = document.getElementById('tl-detail-title');
    const subEl = document.getElementById('tl-detail-sub');
    const bodyEl = document.getElementById('tl-detail-body');
    if (!overlay || !closeBtn || !metaEl || !titleEl || !subEl || !bodyEl) return;

    const expList = experiences as {
      title: string;
      company: string;
      date: string;
      desc: string | null;
      long: string;
      current: boolean;
    }[];
    const eduList = education as {
      title: string;
      university: string;
      date: string;
      long: string;
      current: boolean;
    }[];

    function openOverlay(kind: 'exp' | 'edu', index: number) {
      if (kind === 'exp') {
        const e = expList[index];
        if (!e) return;
        metaEl.textContent = e.date;
        titleEl.textContent = e.title;
        subEl.textContent = e.company;
        bodyEl.textContent = e.long;
      } else {
        const e = eduList[index];
        if (!e) return;
        metaEl.textContent = e.date;
        titleEl.textContent = e.title;
        subEl.textContent = e.university;
        bodyEl.textContent = e.long;
      }
      overlay.hidden = false;
      document.body.classList.add('timeline-detail-open');
      closeBtn.focus();
    }

    function closeOverlay() {
      overlay.hidden = true;
      document.body.classList.remove('timeline-detail-open');
    }

    document.querySelectorAll<HTMLElement>('[data-timeline-kind][data-timeline-index]').forEach((el) => {
      const kind = el.dataset.timelineKind as 'exp' | 'edu';
      const idx = Number(el.dataset.timelineIndex);
      const onActivate = (ev: Event) => {
        ev.stopPropagation();
        openOverlay(kind, idx);
      };
      el.addEventListener('click', onActivate);
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openOverlay(kind, idx);
        }
      });
    });

    closeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      closeOverlay();
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeOverlay();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) closeOverlay();
    });
  }

  document.addEventListener('DOMContentLoaded', initTimelineDetail);
  document.addEventListener('astro:page-load', initTimelineDetail);
</script>

<style>
  .timeline-root {
    position: relative;
  }

  .timeline-wrapper {
    width: 100%;
  }

  /* ── Zigzag Timeline ─────────────────────────────── */
  .timeline {
    position: relative;
    max-width: 100%;
    padding: 1rem 0 3rem;
  }

  .timeline-spine {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 3px; /* Daha kalın ve belirgin */
    background: var(--text-accent); /* Net, düz renk */
    transform: translateX(-50%);
    transform-origin: top;
    animation: drawTimeline 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes drawTimeline {
    0% { height: 0; }
    100% { height: 100%; }
  }

  .timeline-item {
    position: relative;
    width: 50%;
    padding: 0 3rem 2.5rem;
    display: flex;
    flex-direction: column;
  }

  .timeline-item--openable {
    cursor: pointer;
  }

  .timeline-item--openable:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 4px;
  }

  .tl-left {
    padding-right: 3.5rem;
    padding-left: 0;
    align-self: flex-start;
  }

  .tl-right {
    padding-left: 3.5rem;
    padding-right: 0;
    align-self: flex-end;
    margin-left: 50%;
  }

  .timeline-dot {
    position: absolute;
    width: 12px;
    height: 12px;
    background: var(--bg-color);
    border: 2px solid var(--border-color-strong);
    border-radius: 50%;
    top: 20px;
    z-index: 2;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .tl-left .timeline-dot {
    right: -6px;
  }

  .tl-right .timeline-dot {
    left: -6px;
  }

  .timeline-dot.dot-active {
    border-color: var(--text-accent);
    background: var(--text-accent);
  }

  .timeline-item:hover .timeline-dot {
    transform: scale(1.3);
    border-color: var(--text-accent);
  }

  .timeline-card {
    padding: 1.4rem 1.6rem;
    background: rgba(0,0,0,0.02);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  html[data-theme="dark"] .timeline-card {
    background: rgba(255,255,255,0.04);
  }

  .timeline-item--openable:hover .timeline-card {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    background: var(--surface-1);
  }

  html[data-theme="dark"] .timeline-item--openable:hover .timeline-card {
    background: var(--surface-2);
  }

  .tl-card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .tl-date {
    display: inline-block;
    padding: 3px 10px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }

  .tl-badge {
    display: inline-block;
    padding: 3px 10px;
    background: color-mix(in srgb, var(--text-accent) 12%, transparent 88%);
    border: 1px solid color-mix(in srgb, var(--text-accent) 25%, transparent 75%);
    border-radius: var(--radius-pill);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-accent);
    font-family: var(--font-sans);
  }

  .tl-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-main);
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }

  .tl-company {
    display: block;
    font-size: 0.88rem;
    color: var(--text-accent);
    margin-bottom: 0.75rem;
    font-family: var(--font-sans);
  }

  .tl-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* ── Lower sections ──────────────────────────────── */
  .lower-sections {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border-color);
  }

  .lower-heading {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text-main);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  /* Education */
  .edu-list { display: flex; flex-direction: column; gap: 1.5rem; }

  .edu-item { display: flex; flex-direction: column; gap: 0.25rem; }

  .edu-item--openable {
    cursor: pointer;
    padding: 1rem 1.1rem;
    margin: 0 -1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .edu-item--openable:hover {
    background: rgba(0,0,0,0.03);
    border-color: var(--border-color);
    box-shadow: var(--shadow-sm);
  }

  html[data-theme="dark"] .edu-item--openable:hover {
    background: rgba(255,255,255,0.05);
  }

  .edu-item--openable:focus-visible {
    outline: 2px solid var(--text-accent);
    outline-offset: 2px;
  }

  .edu-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .edu-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }

  .edu-current {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-accent);
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--text-accent) 10%, transparent 90%);
    border: 1px solid color-mix(in srgb, var(--text-accent) 20%, transparent 80%);
  }

  .edu-title {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--text-main);
  }

  .edu-uni {
    font-size: 0.85rem;
    color: var(--text-accent);
    font-family: var(--font-sans);
  }

  /* Clean list */
  .clean-list { list-style: none; }

  .clean-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.92rem;
    font-family: var(--font-sans);
    transition: color 0.2s ease, padding-left 0.2s ease;
    cursor: default;
  }

  .clean-list li:last-child { border-bottom: none; }

  .clean-list li:hover {
    color: var(--text-main);
    padding-left: 6px;
  }

  /* Detail overlay */
  .tl-detail-overlay {
    position: fixed;
    inset: 0;
    z-index: 400;
    background: var(--bg-color);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: clamp(1.25rem, 4vw, 2.5rem);
    overflow-y: auto;
    animation: tlFadeIn 0.35s ease;
  }

  .tl-detail-overlay[hidden] {
    display: none !important;
  }

  @keyframes tlFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .tl-detail-close {
    position: fixed;
    top: clamp(1rem, 3vw, 1.75rem);
    right: clamp(1rem, 3vw, 1.75rem);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--surface-1);
    color: var(--text-main);
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    z-index: 410;
    transition: transform var(--transition-fast), background var(--transition-fast);
  }

  .tl-detail-close:hover {
    transform: scale(1.06) rotate(90deg);
    background: var(--text-main);
    color: var(--surface-1);
  }

  .tl-detail-inner {
    max-width: 720px;
    margin: 4rem auto 3rem;
    width: 100%;
  }

  .tl-detail-meta {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: var(--font-sans);
    margin-bottom: 0.75rem;
  }

  .tl-detail-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    color: var(--text-main);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .tl-detail-sub {
    font-size: 1rem;
    color: var(--text-accent);
    font-family: var(--font-sans);
    margin-bottom: 1.75rem;
  }

  .tl-detail-body {
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--ink-mid);
    font-family: var(--font-sans);
    white-space: pre-wrap;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .timeline-spine { left: 20px; }

    .timeline-item {
      width: 100%;
      padding: 0 0 2rem 50px;
    }

    .tl-left,
    .tl-right {
      padding-right: 0;
      padding-left: 50px;
      margin-left: 0;
      align-self: flex-start;
    }

    .tl-left .timeline-dot,
    .tl-right .timeline-dot {
      left: 14px;
      right: auto;
    }

    .lower-sections {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
