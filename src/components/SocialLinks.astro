---

<div class="social-links-container">
  {socialLinks.map((link) => (
    <a 
      href={link.url} 
      class="social-icon" 
      target="_blank" 
      rel="noopener noreferrer" 
      aria-label={link.ariaLabel}
      title={link.name}
    >
      <Fragment set:html={link.svg} />
    </a>
  ))}
</div>

<style>
  .social-links-container {
    display: flex;
    gap: 1.2rem;
    align-items: center;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--ink-high); /* Default color before brand override */
    transition: transform var(--transition-bounce), filter var(--transition-fast);
    text-decoration: none;
  }

  /* Kendi renkleri (Native Brand Colors) */
  .social-icon[title="Gmail"] { color: #D14836; }
  .social-icon[title="LinkedIn"] { color: #0A66C2; }
  .social-icon[title="GitHub"] { color: #181717; }

  :global(html[data-theme="dark"]) .social-icon[title="GitHub"] {
    color: #e8e8e8;
  }
  .social-icon[title="Medium"] { color: #000000; }
  .social-icon[title="Etsy"] { color: #F16521; }

  .social-icon:hover {
    transform: translateY(-4px) scale(1.1);
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
  }

  /* Responsive ayarlar */
  @media (max-width: 768px) {
    .social-links-container {
      gap: 0.8rem;
    }
    .social-icon {
      width: 28px;
      height: 28px;
    }
  }
</style>
