    thumbnail: '/storyline/project-6/PedaTechStudio/story_content/thumbnail.jpg',
  },
  {
    categoryKey: 'storyline',
    category: t('port.cat.storyline'),
    title: t('port.10.title'),
    desc: t('port.10.desc'),
    embedUrl: null as string | null,
    thumbnail: null as string | null,
  },
  {
    categoryKey: 'storyline',
    category: t('port.cat.storyline'),
    title: t('port.11.title'),
    desc: t('port.11.desc'),
