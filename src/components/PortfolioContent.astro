    thumbnail: '/storyline/project-4/cokanlamlisozcukler/story_content/thumbnail.jpg',
  },
  {
    categoryKey: 'storyline',
    category: t('port.cat.storyline'),
    title: t('port.8.title'),
    desc: t('port.8.desc'),
    embedUrl: '/storyline/project-5/Mod%C3%BCl%20Sablonu/story.html',
    thumbnail: '/storyline/project-5/Mod%C3%BCl%20Sablonu/story_content/thumbnail.jpg',
