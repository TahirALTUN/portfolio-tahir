---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import SocialLinks from './SocialLinks.astro';

interface Props {
  lang: 'en' | 'tr';
}

const { lang } = Astro.props;
const homeHref = lang === 'tr' ? '/tr' : '/';
---

<header class="top-navbar">
  <div class="nav-content">
    <div class="nav-left">
      <a href={homeHref} class="nav-logo" aria-label={lang === 'tr' ? 'Ana sayfa' : 'Home'}>T. ALTUN</a>
    </div>
    
    <div class="nav-right">
      <SocialLinks />
      <div class="nav-divider"></div>
      <div class="nav-controls">
        <LanguageSwitcher />
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<style>
  .top-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 72px;
    background: var(--bg);
    z-index: 500; /* Çok üstte durmalı ki kartlar onu ezmesin (ama expands üstünde) */
    display: flex;
    align-items: center;
    border-bottom: 2px solid var(--surface-3); /* Tok ve net çizgi */
  }

  /* Make sure navbar fades out when a card expands so it doesn't block the fullscreen card */
  :global(.has-expanded) .top-navbar {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .top-navbar {
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  /* Intro gizlenmesi */
  :global(.is-intro) .top-navbar {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-20px);
    animation: none;
  }

  .nav-content {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left {
    display: flex;
    align-items: center;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink-high);
    text-decoration: none;
    letter-spacing: -0.02em;
    border: 2px solid var(--ink-high);
    padding: 0.35rem 0.85rem;
    display: inline-block;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .nav-logo:hover {
    background: var(--ink-high);
    color: var(--surface-1);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-controls {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-divider {
    width: 2px;
    height: 24px;
    background-color: var(--surface-3);
  }

  @media (max-width: 768px) {
    .nav-content {
      padding: 0 1.5rem;
    }
    .nav-logo {
      font-size: 1.25rem;
    }
  }
</style>
